# ============================================================================
# PNEUMONIA FORECASTING PROJECT - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this file to .env and customize values as needed.
# See pneumonia/config.py for detailed descriptions of each setting.
#
# Example:
#   $ cp .env.example .env
#   $ # Edit .env with your values
#

# =============================================================================
# DATABASE (for future use)
# =============================================================================
# PostgreSQL connection string (not currently used)
DATABASE_URL=postgresql://user:password@localhost:5432/pneumonia
# =============================================================================
# REPRODUCIBILITY
# =============================================================================
# Random seed for reproducible results across runs
RANDOM_SEED=42


# =============================================================================
# DATA PATHS
# =============================================================================
# Directory containing raw data files (e.g., iras_data_raw.csv)
DATA_RAW_PATH=data/raw/

# Directory containing external data (e.g., population, demographics)
DATA_EXTERNAL_PATH=data/external/

# Directory containing processed data (intermediate results)
DATA_PROCESSED_PATH=data/processed/

# Directory containing interim data (temporary working files)
DATA_INTERIM_PATH=data/interim/


# =============================================================================
# MODEL STORAGE & LOGGING
# =============================================================================
# Directory where trained models will be saved (pickled)
MODEL_STORAGE_PATH=models/

# Directory where training logs will be saved
LOG_PATH=logs/

# Directory where reports and evaluation results will be saved
REPORTS_PATH=reports/


# =============================================================================
# TEMPORAL SPLIT STRATEGY
# =============================================================================
# Strategy for splitting data into train/val/test:
#   'dynamic' - Calculate split automatically from data length (recommended)
#   'years'   - Use fixed year ranges (legacy, less flexible)
TEMPORAL_SPLIT_STRATEGY=dynamic

# For DYNAMIC split: Fraction of data for each set (must sum to 1.0)
# Example: 80% train, 10% val, 10% test
TRAIN_RATIO=0.8
VAL_RATIO=0.1
TEST_RATIO=0.1

# For YEARS split: Year ranges (only used if TEMPORAL_SPLIT_STRATEGY=years)
# Note: These are deprecated, prefer DYNAMIC strategy for new projects
# TRAIN_YEARS_START=2000
# TRAIN_YEARS_END=2019
# VAL_YEARS_START=2020
# VAL_YEARS_END=2021
# TEST_YEARS_START=2022
# TEST_YEARS_END=2023


# =============================================================================
# SARIMA MODEL CONFIGURATION
# =============================================================================
# Use automatic ARIMA parameter search (pmdarima.auto_arima)
#   true  - Automatically find best (p,d,q)×(P,D,Q,s) for each department
#   false - Use default parameters from pneumonia/models/sarima/config.py
USE_AUTO_ARIMA=True

# Maximum iterations for SARIMA fitting (relevant for auto_arima)
SARIMA_MAX_ITERATIONS=400

# Use stepwise algorithm (faster, recommended for large search spaces)
SARIMA_STEPWISE=True

# Print progress information during auto_arima search
SARIMA_TRACE=False



